# EBGeo360 — catalogo de variaveis de ambiente
#
# Copie para `.env` e ajuste. Todas tem valor padrao no codigo (src/config.js),
# entao o servico sobe sem nenhuma delas; este arquivo existe para documentar
# o que e ajustavel e com que valor.
#
# Este servico NAO usa credencial, token nem senha: ele so le arquivos SQLite
# do disco e serve por HTTP. Se algum dia passar a usar, o valor fica so no
# `.env` (que e gitignored) e aqui entra apenas a CHAVE, nunca o valor.

# Porta HTTP do servico.
PORT=8081

# Interface de escuta. 0.0.0.0 aceita conexao de fora da maquina;
# use 127.0.0.1 para restringir ao proprio computador.
HOST=0.0.0.0

# Diretorio raiz dos dados. Precisa conter:
#   index.db          metadados, grafo de navegacao e indice espacial
#   projects/*.db     imagens WebP por projeto (BLOBs)
#   thumbnails/*.webp miniatura por projeto
# Caminho relativo e resolvido a partir da raiz do repo.
STREETVIEW_DATA_DIR=./data

# Nivel de log do Fastify: fatal, error, warn, info, debug, trace, silent.
LOG_LEVEL=info

# Origens permitidas por CORS. `*` libera qualquer origem, o que serve para
# desenvolvimento local com o ebgeo_web. Em producao, restrinja a origem do
# frontend, por exemplo: https://ebgeo.exemplo.mil.br
CORS_ORIGIN=*
